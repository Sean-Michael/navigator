# Copy to .env and fill in. All vars are prefixed NAVIGATOR_.

# Path to the built frontend (dist/). Leave unset in dev — Vite serves the UI.
# NAVIGATOR_STATIC_DIR=/app/static

# GitHub personal access token for PR/commit data.
# NAVIGATOR_GITHUB_TOKEN=

# Allowed CORS origins in dev (JSON list).
# NAVIGATOR_CORS_ORIGINS=["http://localhost:5173"]

# syntax=docker/dockerfile:1
# Development image: deps baked in, source mounted at runtime for HMR.
FROM node:22-slim
WORKDIR /app

# Patch base-image OS packages and the bundled npm (clears fixable CVEs the
# scan flags in node:22-slim, including npm's vendored picomatch).
RUN apt-get update \
    && apt-get upgrade -y \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g npm@latest

COPY package.json package-lock.json ./
RUN npm ci

EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host"]
